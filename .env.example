# Server-side (never commit real secret keys)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Admin panel (/admin) — password login + optional Supabase storage
ADMIN_SECRET=choose-a-long-random-string
# Service role for saving daily overrides in production (Dashboard → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=

# Browser client — mirror URL + publishable key with NEXT_PUBLIC_ prefix
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
